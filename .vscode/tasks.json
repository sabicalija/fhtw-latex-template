{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "FHTW: LaTeX Build",
      "type": "shell",
      "command": "latexmk",
      "args": [
        "${file}"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "FHTW: LaTeX Clean",
      "type": "shell",
      "command": "latexmk",
      "args": [
        "-c",
        "${file}"
      ],
      "presentation": {
        "reveal": "silent"
      }
    }
  ]
}